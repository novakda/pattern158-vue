# Feedback Collector Configuration (dev/staging only)
# Copy to .env.local and fill in values
# See: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens

# GitHub Personal Access Token
# Required scopes: public_repo + gist (classic token)
# Recommended: create a dedicated bot account, not your personal account
# Token expiration: set to 90 days max
VITE_GITHUB_TOKEN=

# GitHub repository for issue creation (format: owner/repo)
VITE_GITHUB_REPO=

# Issue labels (optional, comma-separated, default: "feedback")
VITE_GITHUB_LABELS=feedback
