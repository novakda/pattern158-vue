{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": ".tsbuildinfo-scripts",
    "rootDir": ".",
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "paths": {},
    "baseUrl": "."
  },
  "include": [
    "scripts/markdown-export/**/*.ts",
    "scripts/tiddlywiki/**/*.ts"
  ],
  "exclude": [
    "scripts/tiddlywiki/generate.ts",
    "scripts/tiddlywiki/sources.ts",
    "scripts/tiddlywiki/sources.test.ts",
    "scripts/tiddlywiki/html-to-wikitext.ts",
    "scripts/tiddlywiki/verify-integrity.ts"
  ]
}
